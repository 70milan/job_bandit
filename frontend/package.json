{
  "name": "windows-runtime-host",
  "version": "2.0.65",
  "description": "Interview Assistant - Secure Windows Runtime Host",
  "author": "mjulez70 <mjulez70@gmail.com>",
  "productName": "Interview Assistant",
  "main": "main.js",
  "scripts": {
    "start": "npm run electron",
    "start:dev": "concurrently --kill-others \"npm run electron\" \"cd ../backend && uvicorn main:app --port 5050\"",
    "electron": "electron .",
    "prebuild": "node bump-version.js",
    "obfuscate": "node scripts/obfuscate.js obfuscate",
    "restore": "node scripts/obfuscate.js restore",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.windowsruntimehost.app",
    "productName": "Windows Runtime Host",
    "publish": {
      "provider": "github",
      "owner": "mjulez70",
      "repo": "job_bandit",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/WinHostSvc.exe",
        "to": "backend/WinHostSvc.exe"
      }
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "executableName": "Realtime_ContextEngine",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": "../windows-runtime-host.pfx",
      "publisherName": "mjulez70"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "Windows-Runtime-Host-Setup-${version}.${ext}"
    },
    "extraMetadata": {
      "main": "main.js"
    },
    "forceCodeSigning": true
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.4.0",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^4.1.1"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  }
}
